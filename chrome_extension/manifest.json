{
  "manifest_version": 3,
  "name": "ML Review Predictor",
  "version": "1.1",
  "description": "Przewiduje gwiazdki z zaznaczonego tekstu używając lokalnego modelu ML.",
  "permissions": ["contextMenus", "scripting", "activeTab", "storage"],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": ["http://127.0.0.1:5000/*", "http://localhost:5000/*"]
}